          "max": 60
        }
      ],
      "pair": [
        {
          "id": "login_credentials",
          "template": "login_credentials",
          "options": {
            "hint": { "en": "Enter your Škoda Connect account credentials" },
            "usernameLabel": { "en": "Škoda Connect Email" },
            "passwordLabel": { "en": "Škoda Connect Password" }
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": { "next": "add_devices" }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ]
    }
  ]
}
