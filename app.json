          }
        ]
      },
      "energy": {
        "batteries": ["INTERNAL"]
      },
      "images": {
        "small": "/drivers/skoda/assets/images/small.png",
        "large": "/drivers/skoda/assets/images/large.png",
        "xlarge": "/drivers/skoda/assets/images/xlarge.png"
      },
      "settings": [
        {
          "id": "vin",
          "type": "label",
          "label": { "en": "Vehicle VIN" },
          "value": ""
        },
        {
          "id": "spin",
          "type": "password",
          "label": { "en": "S-PIN (Security PIN)" },
