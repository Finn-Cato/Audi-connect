{
  "id": "com.audi.connect",
  "version": "0.1.0",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "name": { "en": "VAG Connect" },
  "description": { "en": "Control your Audi, Volkswagen or Škoda. Lock/unlock, climate, charging & live data via the official connected-car API." },
  "category": ["security"],
  "brandColor": "#1A1A1A",
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": { "name": "" },
  "capabilities": {
    "charging_status": {
      "type": "enum",
      "title": { "en": "Charging Status" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/capabilities/charging_status.svg",
      "values": [
        { "id": "charging",             "title": { "en": "Charging" } },
        { "id": "charged",              "title": { "en": "Fully Charged" } },
        { "id": "notReadyForCharging",  "title": { "en": "Not ready" } },
        { "id": "readyForCharging",     "title": { "en": "Ready to charge" } },
        { "id": "conserving",           "title": { "en": "Conserving" } },
        { "id": "invalid",             "title": { "en": "Unknown" } }
      ]
    },
    "measure_range": {
      "type": "number",
      "title": { "en": "Range" },
      "units": { "en": "km" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/capabilities/measure_range.svg",
      "decimals": 0,
      "min": 0
    },
    "climate_on": {
      "type": "boolean",
      "title": { "en": "Climate" },
      "getable": true,
      "setable": true,
      "uiComponent": "toggle",
      "icon": "/assets/capabilities/climate_on.svg",
      "insights": false
    },
    "climate_temperature": {
      "type": "number",
      "title": { "en": "Target Temperature" },
      "units": { "en": "°C" },
      "getable": true,
      "setable": true,
      "uiComponent": "slider",
      "icon": "/assets/capabilities/climate_on.svg",
      "min": 16,
      "max": 30,
      "step": 0.5,
      "decimals": 1
    },
    "climate_window_heat": {
      "type": "boolean",
      "title": { "en": "Window Heating" },
      "getable": true,
      "setable": true,
      "uiComponent": "toggle",
      "icon": "/assets/capabilities/climate_on.svg",
      "insights": false
    }
  },
  "flow": {
    "actions": [
      {
        "id": "start_climate",
        "title": { "en": "Start pre-conditioning" },
        "args": [{ "type": "device", "name": "device", "filter": "driver_id=audi|driver_id=vw|driver_id=skoda" }]
      },
      {
        "id": "stop_climate",
        "title": { "en": "Stop pre-conditioning" },
        "args": [{ "type": "device", "name": "device", "filter": "driver_id=audi|driver_id=vw|driver_id=skoda" }]
      },
      {
        "id": "start_charging",
        "title": { "en": "Start charging" },
        "args": [{ "type": "device", "name": "device", "filter": "driver_id=audi|driver_id=vw|driver_id=skoda" }]
      },
      {
        "id": "stop_charging",
        "title": { "en": "Stop charging" },
        "args": [{ "type": "device", "name": "device", "filter": "driver_id=audi|driver_id=vw|driver_id=skoda" }]
      }
    ],
    "triggers": [
      {
        "id": "charging_started",
        "title": { "en": "Charging started" },
        "args": [{ "type": "device", "name": "device", "filter": "driver_id=audi|driver_id=vw|driver_id=skoda" }]
      },
      {
        "id": "charging_stopped",
        "title": { "en": "Charging stopped" },
        "args": [{ "type": "device", "name": "device", "filter": "driver_id=audi|driver_id=vw|driver_id=skoda" }]
      }
    ],
    "conditions": [
      {
        "id": "is_charging",
        "title": { "en": "Car !{{is|is not}} charging" },
        "args": [{ "type": "device", "name": "device", "filter": "driver_id=audi|driver_id=vw|driver_id=skoda" }]
      }
    ]
  },
  "drivers": [
    {
      "id": "audi",
      "name": { "en": "Audi Vehicle" },
      "class": "other",
      "capabilities": [
        "locked",
        "measure_battery",
        "alarm_battery",
        "charging_status",
        "measure_range",
        "climate_on",
        "climate_temperature",
        "climate_window_heat"
      ],
      "mobile": {
        "components": [
          {
            "id": "icon",
            "capabilities": ["locked"]
          },
          {
            "id": "sensor",
            "capabilities": ["measure_battery", "alarm_battery", "charging_status", "measure_range"]
          },
          {
            "id": "toggle",
            "capabilities": ["locked"]
          },
          {
            "id": "separator"
          },
          {
            "id": "sensor",
            "capabilities": ["climate_on"]
          },
          {
            "id": "slider",
            "capabilities": ["climate_temperature"]
          },
          {
            "id": "toggle",
            "capabilities": ["climate_window_heat"]
          },
          {
            "id": "toggle",
            "capabilities": ["climate_on"]
          }
        ]
      },
      "energy": {
        "batteries": ["INTERNAL"]
      },
      "images": {
        "small": "/drivers/audi/assets/images/small.png",
        "large": "/drivers/audi/assets/images/large.png",
        "xlarge": "/drivers/audi/assets/images/xlarge.png"
      },
      "settings": [
        {
          "id": "vin",
          "type": "label",
          "label": { "en": "Vehicle VIN" },
          "value": ""
        },
        {
          "id": "spin",
          "type": "password",
          "label": { "en": "S-PIN (Security PIN)" },
          "hint": { "en": "Required for lock/unlock on some Audi models" },
          "value": ""
        },
        {
          "id": "poll_interval",
          "type": "number",
          "label": { "en": "Poll interval (minutes)" },
          "value": 5,
          "min": 2,
          "max": 60
        }
      ],
      "pair": [
        {
          "id": "login_credentials",
          "template": "login_credentials",
          "options": {
            "hint": { "en": "Enter your myAudi account credentials (same as the myAudi app)" },
            "usernameLabel": { "en": "myAudi Email" },
            "passwordLabel": { "en": "myAudi Password" }
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": { "next": "add_devices" }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ]
    },
    {
      "id": "vw",
      "name": { "en": "Volkswagen Vehicle" },
      "class": "other",
      "capabilities": [
        "locked",
        "measure_battery",
        "alarm_battery",
        "charging_status",
        "measure_range",
        "climate_on",
        "climate_temperature",
        "climate_window_heat"
      ],
      "mobile": {
        "components": [
