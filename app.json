            "id": "sensor",
            "capabilities": ["measure_battery", "alarm_battery", "charging_status", "measure_range"]
          },
          {
            "id": "toggle",
            "capabilities": ["locked"]
          },
          {
            "id": "separator"
          },
          {
            "id": "sensor",
            "capabilities": ["climate_on"]
          },
          {
            "id": "slider",
            "capabilities": ["climate_temperature"]
          },
          {
            "id": "toggle",
            "capabilities": ["climate_window_heat"]
          },
          {
            "id": "toggle",
            "capabilities": ["climate_on"]
          }
        ]
      },
      "energy": {
        "batteries": ["INTERNAL"]
      },
      "images": {
        "small": "/drivers/vw/assets/images/small.png",
        "large": "/drivers/vw/assets/images/large.png",
        "xlarge": "/drivers/vw/assets/images/xlarge.png"
      },
      "settings": [
        {
          "id": "vin",
          "type": "label",
          "label": { "en": "Vehicle VIN" },
          "value": ""
        },
        {
          "id": "spin",
          "type": "password",
          "label": { "en": "S-PIN (Security PIN)" },
          "hint": { "en": "Required for lock/unlock on some models" },
          "value": ""
        },
        {
          "id": "poll_interval",
          "type": "number",
          "label": { "en": "Poll interval (minutes)" },
          "value": 5,
          "min": 2,
          "max": 60
        }
      ],
      "pair": [
        {
          "id": "login_credentials",
          "template": "login_credentials",
          "options": {
            "hint": { "en": "Enter your Volkswagen We Connect account credentials" },
            "usernameLabel": { "en": "We Connect Email" },
            "passwordLabel": { "en": "We Connect Password" }
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": { "next": "add_devices" }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ]
    },
    {
      "id": "skoda",
      "name": { "en": "Škoda Vehicle" },
      "class": "other",
      "capabilities": [
        "locked",
        "measure_battery",
        "alarm_battery",
        "charging_status",
        "measure_range",
        "climate_on",
        "climate_temperature",
        "climate_window_heat"
      ],
      "mobile": {
        "components": [
          {
            "id": "icon",
            "capabilities": ["locked"]
          },
          {
            "id": "sensor",
            "capabilities": ["measure_battery", "alarm_battery", "charging_status", "measure_range"]
          },
          {
            "id": "toggle",
            "capabilities": ["locked"]
          },
          {
            "id": "separator"
          },
          {
            "id": "sensor",
            "capabilities": ["climate_on"]
          },
          {
            "id": "slider",
